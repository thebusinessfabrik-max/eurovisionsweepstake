    };

    function shuffle(array) {
      const copy = [...array];
      for (let i = copy.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [copy[i], copy[j]] = [copy[j], copy[i]];
      }
      return copy;
    }

    const grid = document.getElementById('heartsGrid');
    const template = document.getElementById('heartTemplate');
    const statusText = document.getElementById('statusText');
    const resetButton = document.getElementById('resetBoard');
    let assignedEntries = shuffle(entries);

    function renderBoard() {
      grid.innerHTML = '';
      assignedEntries.forEach((entry, index) => {
        const node = template.content.cloneNode(true);
        const card = node.querySelector('.heart-card');
        const button = node.querySelector('.heart-button');

        const countryEl = node.querySelector('.country');
        countryEl.textContent = entry.country;

        const flagImg = node.querySelector('.flag');
        const flagUrl = flagMap[entry.country];
        if (flagUrl) {
          flagImg.src = flagUrl;
        } else {
          flagImg.style.display = 'none';
        }

        node.querySelector('.song').textContent = entry.song;
        node.querySelector('.artist').textContent = entry.artist;

        button.setAttribute('aria-label', `Reveal entry ${index + 1}`);
        button.addEventListener('click', () => {
          const revealed = card.classList.toggle('revealed');
          button.setAttribute('aria-expanded', String(revealed));
          updateStatus();
        });
        grid.appendChild(node);
      });
      updateStatus();
    }

    function updateStatus() {
      const revealed = document.querySelectorAll('.heart-card.revealed').length;
      statusText.innerHTML = `<strong>${revealed}</strong> of <strong>${assignedEntries.length}</strong> hearts revealed.`;
    }

    resetButton.addEventListener('click', () => {
      assignedEntries = shuffle(entries);
      renderBoard();
    });

    renderBoard();
  </script>
</body>
</html>
