            <path d="M50 74C36 61 18 47 18 28.5C18 21.5 23 16 30 16C37 16 43 20.5 46.5 27.5L50 34L53.5 27.5C57 20.5 63 16 70 16C77 16 82 21.5 82 28.5C82 47 64 61 50 74Z" fill="rgba(255,255,255,0.15)"/>
