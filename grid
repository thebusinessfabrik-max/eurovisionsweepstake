<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Eurovision 2026 Sweepstake</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root, [data-theme="light"] {
      --text-xs: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
      --text-sm: clamp(0.875rem, 0.8rem + 0.35vw, 1rem);
      --text-base: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
      --text-lg: clamp(1.125rem, 1rem + 0.75vw, 1.5rem);
      --text-xl: clamp(1.5rem, 1.2rem + 1.25vw, 2.25rem);
      --space-1: 0.25rem; --space-2: 0.5rem; --space-3: 0.75rem; --space-4: 1rem;
      --space-5: 1.25rem; --space-6: 1.5rem; --space-8: 2rem; --space-10: 2.5rem;
      --space-12: 3rem; --space-16: 4rem;
      --radius-sm: 0.375rem; --radius-md: 0.5rem; --radius-lg: 0.75rem; --radius-xl: 1rem; --radius-full: 9999px;
      --transition-interactive: 220ms cubic-bezier(0.16, 1, 0.3, 1);
      --color-bg: #0b0b12;
      --color-surface: rgba(255,255,255,0.06);
      --color-surface-2: rgba(255,255,255,0.1);
      --color-border: rgba(255,255,255,0.12);
      --color-divider: rgba(255,255,255,0.08);
      --color-text: #ffffff;
      --color-text-muted: rgba(255,255,255,0.72);
      --color-text-faint: rgba(255,255,255,0.48);
      --color-text-inverse: #0b0b12;
      --color-primary: #00a7ff;
      --color-primary-hover: #39b8ff;
      --color-accent: #ff004f;
      --color-accent-2: #ff2e7a;
      --color-heart-stroke: rgba(255,255,255,0.95);
      --shadow-lg: 0 18px 40px rgba(0,0,0,0.35);
      --font-display: 'Outfit', system-ui, sans-serif;
      --font-body: 'Space Grotesk', system-ui, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-text-size-adjust: none; text-size-adjust: none; scroll-behavior: smooth; }
    body {
      min-height: 100vh;
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      background:
        radial-gradient(circle at top, rgba(255, 0, 95, 0.45), transparent 32%),
        linear-gradient(180deg, #d10037 0%, #8a0028 38%, #28000d 100%);
      overflow-x: hidden;
    }

    .page {
      min-height: 100vh;
      padding: clamp(var(--space-4), 3vw, var(--space-8));
      display: grid;
      place-items: center;
    }

    .board {
      width: min(100%, 980px);
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
      border: 1px solid var(--color-border);
      border-radius: 28px;
      box-shadow: var(--shadow-lg);
      backdrop-filter: blur(12px);
      overflow: hidden;
    }

    .header {
      padding: clamp(var(--space-5), 4vw, var(--space-10));
      border-bottom: 1px solid var(--color-divider);
      text-align: center;
    }

    .eyebrow {
      font-size: var(--text-sm);
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: rgba(255,255,255,0.8);
      margin-bottom: var(--space-3);
    }

    h1 {
      font-family: var(--font-display);
      font-size: var(--text-xl);
      line-height: 1.05;
      margin-bottom: var(--space-3);
    }

    .intro {
      max-width: 55ch;
      margin: 0 auto;
      color: var(--color-text-muted);
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-3);
      margin-top: var(--space-5);
      color: var(--color-text-faint);
      font-size: var(--text-sm);
    }

    .legend span {
      padding: 0.55rem 0.9rem;
      border-radius: var(--radius-full);
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .grid-wrap {
      padding: clamp(var(--space-4), 4vw, var(--space-8));
    }

    .hearts-grid {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: clamp(10px, 1.8vw, 18px);
      align-items: stretch;
    }

    .heart-card {
      position: relative;
      aspect-ratio: 0.78 / 1;
      perspective: 1200px;
      min-height: 96px;
    }

    .heart-button {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      background: transparent;
      cursor: pointer;
      transform-style: preserve-3d;
      transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1), filter var(--transition-interactive);
      border-radius: 20px;
      min-width: 44px;
      min-height: 44px;
    }

    .heart-card.revealed .heart-button {
      transform: rotateY(180deg);
    }

    .heart-face,
    .entry-face {
      position: absolute;
      inset: 0;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-3);
    }

    .heart-face {
      background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
      border: 1px solid rgba(255,255,255,0.08);
    }

    .heart-button:hover .heart-face,
    .heart-button:focus-visible .heart-face {
      background: linear-gradient(180deg, rgba(255,255,255,0.11), rgba(255,255,255,0.05));
      border-color: rgba(255,255,255,0.18);
    }

    .entry-face {
      transform: rotateY(180deg);
      background: linear-gradient(180deg, rgba(0,167,255,0.2), rgba(255,0,79,0.22));
      border: 1px solid rgba(255,255,255,0.16);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.15);
      text-align: center;
    }

    .heart-icon {
      width: 72%;
      max-width: 82px;
      filter: drop-shadow(0 8px 18px rgba(0,0,0,0.18));
      transition: transform var(--transition-interactive), filter var(--transition-interactive);
    }

    .heart-button:hover .heart-icon,
    .heart-button:focus-visible .heart-icon {
      transform: scale(1.04);
      filter: drop-shadow(0 10px 22px rgba(0,0,0,0.25));
    }

    .entry-content {
      display: grid;
      gap: 0.32rem;
      align-content: center;
    }

    .country-row {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
    }

    .flag {
      width: 1.15rem;
      height: 1.15rem;
      border-radius: 999px;
      object-fit: cover;
      box-shadow: 0 0 0 1px rgba(255,255,255,0.65);
    }

    .country {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: clamp(0.88rem, 0.55rem + 0.9vw, 1.1rem);
      line-height: 1.05;
    }

    .song {
      font-size: clamp(0.7rem, 0.48rem + 0.55vw, 0.88rem);
      color: rgba(255,255,255,0.94);
      line-height: 1.2;
    }

    .artist {
      font-size: clamp(0.68rem, 0.46rem + 0.45vw, 0.82rem);
      color: rgba(255,255,255,0.7);
      line-height: 1.2;
    }

    .status {
      padding: 0 var(--space-8) var(--space-6);
      text-align: center;
      color: var(--color-text-muted);
      font-size: var(--text-sm);
    }

    .status strong { color: var(--color-text); }

    .controls {
      display: flex;
      justify-content: center;
      padding: 0 var(--space-4) var(--space-8);
    }

    .reset-btn {
      padding: 0.9rem 1.25rem;
      border-radius: var(--radius-full);
      background: rgba(255,255,255,0.09);
      color: var(--color-text);
      border: 1px solid rgba(255,255,255,0.12);
      font-weight: 600;
    }

    .reset-btn:hover,
    .reset-btn:focus-visible {
      background: rgba(255,255,255,0.16);
    }

    .heart-button:focus-visible,
    .reset-btn:focus-visible {
      outline: 2px solid #ffffff;
      outline-offset: 3px;
    }

    @media (max-width: 720px) {
      .hearts-grid {
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 10px;
      }
      .board { border-radius: 22px; }
      .heart-face, .entry-face { border-radius: 16px; padding: 0.45rem; }
    }

    @media (max-width: 560px) {
      .page { padding: 12px; }
      .header { padding: 1.1rem 1rem; }
      .grid-wrap { padding: 0.9rem; }
      .status { padding: 0 1rem 1rem; }
      .controls { padding: 0 1rem 1.1rem; }
      .heart-card { aspect-ratio: 0.78 / 1.02; }
      .legend { gap: 0.45rem; }
      .legend span { padding: 0.45rem 0.7rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      .heart-button { transition: none; }
      .heart-icon { transition: none; }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="board" aria-labelledby="page-title">
      <header class="header">
        <div class="eyebrow">Eurovision Song Contest 2026</div>
